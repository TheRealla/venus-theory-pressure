You can paste this in VS‑Code / your editor and run:

```python
import mido
from mido import Message, MidiFile, MidiTrack, MetaMessage, pitchwheel
import random
from pathlib import Path
import tkinter as tk
from tkinter import ttk, messagebox
import threading
import math


# ========================= CONFIG (defaults) =========================
KEY = "A"                  # Change to any root
MODE = "minor"             # "major" or "minor"
PROGRESSION = ["i", "VI", "III", "VII"]  # Venus Theory modal style
OCTAVE_BASS = 2
OCTAVE_CHORDS = 4
TEMPO = 128
DURATION_BEATS = 4
ARP = True                 # Higher‑frequency arp bass (Diva / Jon Audio vibe)
NEURAL_VARIATION = True
PYTHAGOREAN_MODE = True    # Pure 3:2 fifths + pitch‑bend
# =========================================================


# Scales
MAJOR_SCALE = [0, 2, 4, 5, 7, 9, 11]
MINOR_SCALE = [0, 2, 3, 5, 7, 8, 10]


def get_scale(root, mode):
    root_note = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"].index(root)
    scale = MAJOR_SCALE if mode == "major" else MINOR_SCALE
    return [(root_note + deg) % 12 for deg in scale]


def roman_to_base_chord(roman, scale):
    roman_map = {"i":0, "ii":1, "iii":2, "iv":3, "v":4, "vi":5, "vii":6,
                 "I":0, "II":1, "III":2, "IV":3, "V":4, "VI":5, "VII":6}
    degree = roman_map[roman.upper()]
    root = scale[degree]
    if roman.islower():
        triad = [root, (root + 3) % 12, (root + 7) % 12]
        ext = [(root + 10) % 12]
    else:
        triad = [root, (root + 4) % 12, (root + 7) % 12]
        ext = [(root + 11) % 12]
    ninth = (root + 2) % 12
    return triad + ext + [ninth]


class PythagoreanTuner:
    def __init__(self, root_midi=60):
        self.root_midi = root_midi
        self.fifth_ratio_cents = 701.955
        self.octave_cents = 1200.0

    def get_pythagorean_note(self, scale_degree, octave_offset=0):
        fifth_steps = [0, 2, 4, -1, 1, 3, 5, -2, 0, 2, 4, -1][scale_degree]
        cents = fifth_steps * self.fifth_ratio_cents
        while cents >= self.octave_cents:
            cents -= self.octave_cents
        while cents < 0:
            cents += self.octave_cents
        midi_float = self.root_midi + (cents / 100.0)
        midi_note = int(round(midi_float))
        bend_cents = (midi_float - midi_note) * 100.0
        bend_value = int(bend_cents * 81.92)
        return midi_note + (12 * octave_offset), bend_value


class NeuralChoralcelo:
    def __init__(self, scale, pythagorean_tuner=None, neural_variation=True):
        self.scale = scale
        self.neural_variation = neural_variation
        self.pythagorean_tuner = pythagorean_tuner

    def consonance_score(self, note1, note2):
        interval = abs(note1 - note2) % 12
        scores = {0: 10, 7: 9, 5: 8, 4: 7, 3: 6, 9: 5, 2: 4, 11: 3, 1: 1, 6: 0, 8: 2, 10: 2}
        return scores.get(interval, 0)

    def generate_cello_voicing(self, base_chord, octave):
        voicing = []
        root = base_chord[0]
        voicing.append(root + 12 * octave)
        voicing.append((root + 7) % 12 + 12 * octave)
        voicing.append(base_chord [soundonsound](https://www.soundonsound.com/techniques/groove-quantise-part-2) + 12 * (octave + 1))
        if len(base_chord) > 3:
            voicing.append(base_chord [reddit](https://www.reddit.com/r/ableton/comments/1l7b58v/quantizing_swung_midi/) + 12 * octave)
        if len(base_chord) > 4:
            ninth_oct = octave + (1 if random.random() > 0.5 else 2)
            voicing.append(base_chord [sweetwater](https://www.sweetwater.com/insync/quantization-when-and-when-not-to-quantize/) + 12 * ninth_oct)
        if self.neural_variation and random.random() > 0.6:
            eleventh = (root + 5) % 12
            if self.consonance_score(root, eleventh) > 5:
                voicing.append(eleventh + 12 * (octave + 1))
        if self.neural_variation and random.random() > 0.7:
            voicing [soundonsound](https://www.soundonsound.com/techniques/groove-quantise-part-2) -= 12
        voicing = sorted(set(voicing))
        if self.pythagorean_tuner:
            tuned = []
            bends = []
            for n in voicing:
                mn, b = self.pythagorean_tuner.get_pythagorean_note(n % 12, n // 12)
                tuned.append(mn)
                bends.append(b)
            return tuned, bends
        return voicing, None


# ======================== 4×‑BETTER‑THAN‑DAW TIMING ========================
def thick_quantize(note_time_ticks, strength=1.0, ticks_per_beat=480, subdivision=16, bias="straight"):
    """
    DAW‑style but more expressive quantize (4× groove).
    - bias: "straight", "shuffle", "triplet", "vesper"
    """
    if strength == 0.0:
        return note_time_ticks
    base_step = ticks_per_beat // 4  # 120 ticks = 1/16 note
    grid_step = base_step
    if bias == "shuffle":
        grid_step = int(base_step * 0.95)
    elif bias == "triplet":
        grid_step = int(base_step * 2 / 3)
    elif bias == "vesper":
        grid_step = int(base_step * 0.9 + random.uniform(-10, 10))
    nearest = round(note_time_ticks / grid_step) * grid_step
    return int(note_time_ticks + (nearest - note_time_ticks) * strength)


def thick_swing(onset_ticks, note_index, swing_enabled=True, swing_percent=0.60, style="swing_2to1", vibe="pressure"):
    """
    Extra‑groove swing (DAW‑style but Venus‑aware).
    """
    if not swing_enabled:
        return onset_ticks
    if style == "swing_2to1" and (note_index % 2) == 1:
        return onset_ticks + int(onset_ticks * 0.5 * swing_percent)
    if style == "triplet_hip" and (note_index % 2) == 1:
        return onset_ticks + int(onset_ticks * 0.6 * swing_percent)
    if style == "vesper" and (note_index % 2) == 1:
        return onset_ticks + int(onset_ticks * 0.55 * swing_percent)
    return onset_ticks


def create_bass_track(scale, base_onset, progression, arp=False, sixteen_bar=False, swing_enabled=True, swing_style="swing_2to1", vibe="pressure"):
    track = MidiTrack()
    track.append(MetaMessage('set_tempo', tempo=mido.bpm2tempo(TEMPO)))
    loop_mult = 4 if sixteen_bar else 2
    root_deg = 0
    for i, roman in enumerate(progression * loop_mult):
        base = roman_to_base_chord(roman, scale)
        root_deg = base[0]
        root_midi = root_deg + 12 * OCTAVE_BASS
        if PYTHAGOREAN_MODE:
            tuner = PythagoreanTuner(root_midi=60)
            root_midi, bend = tuner.get_pythagorean_note(root_deg, OCTAVE_BASS)
            track.append(pitchwheel(channel=0, pitch=bend, time=0))
        if arp:
            arp_notes = [root_midi, (root_midi + 7) % 12 + 12 * OCTAVE_BASS, root_midi + 12]
            for j, n in enumerate(arp_notes * 2):
                onset = base_onset
                if swing_enabled:
                    onset = thick_swing(onset, j, swing_enabled, 0.6, style=swing_style, vibe=vibe)
                    onset = thick_quantize(onset, 0.85, 480, 16, bias=swing_style)
                track.append(Message('note_on', note=n, velocity=100, time=onset))
                track.append(Message('note_off', note=n, velocity=0, time=60))
        else:
            track.append(Message('note_on', note=root_midi, velocity=110, time=0))
            off_time = int(DURATION_BEATS * 480)
            if swing_enabled:
                off_time = thick_quantize(off_time, 0.85, 480, 16, bias="straight")
            track.append(Message('note_off', note=root_midi, velocity=0, time=off_time))
        track.append(MetaMessage('text', text="SECRET-TAPE-SOURCE → ToTape9 + Slew4", time=0))
    return track, root_deg


def create_chords_track(scale, base_onset, progression, sixteen_bar=False, swing_enabled=True):
    track = MidiTrack()
    choral_celo = NeuralChoralcelo(scale, None, neural_variation=NEURAL_VARIATION)
    loop_mult = 4 if sixteen_bar else 2
    for i, roman in enumerate(progression * loop_mult):
        base_chord = roman_to_base_chord(roman, scale)
        voicing, bends = choral_celo.generate_cello_voicing(base_chord, OCTAVE_CHORDS)
        for j, note in enumerate(voicing):
            vel = random.randint(75, 110)
            attack = 0
            if swing_enabled:
                attack = thick_quantize(0, 0.8, 480, 16, bias="shuffle")
            track.append(Message('note_on', note=note, velocity=vel, time=attack))
            if bends and j < len(bends):
                track.append(pitchwheel(channel=0, pitch=bends[j], time=0))
        gate_time = int(DURATION_BEATS * 480)
        if swing_enabled:
            gate_time = thick_quantize(gate_time, 0.8, 480, 16, bias="shuffle")
        track.append(Message('note_off', note=voicing[0], velocity=0, time=gate_time))
        for note in voicing[1:]:
            track.append(Message('note_off', note=note, velocity=0, time=0))
    return track


# ======================== GUI ========================
def build_gui():
    root = tk.Tk()
    root.title("Venus Pressure Bass – 4× Better Than DAW")
    root.geometry("550x620")

    # --- Variables ---
    key_var = tk.StringVar(value=KEY)
    mode_var = tk.StringVar(value=MODE)
    arp_var = tk.IntVar(value=1 if ARP else 0)
    dur_beats_var = tk.DoubleVar(value=DURATION_BEATS)
    neural_var = tk.IntVar(value=1 if NEURAL_VARIATION else 0)
    pythagorean_var = tk.IntVar(value=1 if PYTHAGOREAN_MODE else 0)
    sixteen_bar_var = tk.IntVar(value=0)  # 8 bars = 0, 16 bars = 1
    swing_quantize_enabled = tk.IntVar(value=1)
    swing_style_var = tk.StringVar(value="swing_2to1")
    vibe_var = tk.StringVar(value="pressure")

    # --- Rows ---
    row = 0

    # Key + Mode
    tk.Label(root, text="Key:").grid(row=row, column=0, sticky="w", padx=10, pady=4)
    key_cbox = ttk.Combobox(
        root, textvariable=key_var,
        values=["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"],
        width=8
    )
    key_cbox.grid(row=row, column=1, sticky="w", padx=10, pady=4)

    tk.Label(root, text="Mode:").grid(row=row, column=2, sticky="w", padx=10, pady=4)
    mode_cbox = ttk.Combobox(
        root, textvariable=mode_var,
        values=["major", "minor"], width=8
    )
    mode_cbox.grid(row=row, column=3, sticky="w", padx=10, pady=4)
    row += 1

    # Progression
    tk.Label(root, text="Progression (Roman):").grid(row=row, column=0, sticky="w", padx=10, pady=4)
    prog_var = tk.StringVar(value=" ".join(PROGRESSION))
    ttk.Entry(root, textvariable=prog_var, width=32).grid(row=row, column=1, columnspan=3, padx=10, pady=4)
    row += 1

    # ARP / Neural / Pythagorean
    arp_check = tk.Checkbutton(root, text="ARP bass (Diva / Jon Audio vibe)", variable=arp_var)
    arp_check.grid(row=row, column=0, columnspan=2, sticky="w", padx=10, pady=4)

    neural_check = tk.Checkbutton(root, text="NeuralChoralcelo variation", variable=neural_var)
    neural_check.grid(row=row, column=2, columnspan=2, sticky="w", padx=10, pady=4)
    row += 1

    pyth_check = tk.Checkbutton(root, text="Pythagorean tuning (3:2 fifths)", variable=pythagorean_var)
    pyth_check.grid(row=row, column=0, columnspan=4, sticky="w", padx=10, pady=4)

    tk.Checkbutton(root, text="16‑bar loop (toggle)", variable=sixteen_bar_var).grid(
        row=row + 1, column=0, columnspan=4, sticky="w", padx=10, pady=4)

    # Duration per chord
    tk.Label(root, text="Duration per chord (beats):").grid(
        row=row + 2, column=0, sticky="w", padx=10, pady=4)
    tk.Scale(
        root, from_=1, to=8, orient="horizontal", resolution=0.5,
        variable=dur_beats_var
    ).grid(row=row + 2, column=1, columnspan=3, sticky="we", padx=10, pady=4)
    row += 3

    # Swing / quantize toggle + style
    tk.Checkbutton(
        root,
        text="4× Better Swing & Quantize (toggle)",
        variable=swing_quantize_enabled
    ).grid(row=row, column=0, columnspan=4, sticky="w", padx=10, pady=4)
    row += 1

    tk.Label(root, text="Swing style:").grid(row=row, column=0, sticky="w", padx=10, pady=2)
    ttk.Combobox(
        root, textvariable=swing_style_var,
        values=["swing_2to1", "triplet_hip", "vesper"], width=10
    ).grid(row=row, column=1, sticky="w", padx=10, pady=2)

    tk.Label(root, text="Vibe:").grid(row=row, column=2, sticky="w", padx=10, pady=2)
    ttk.Combobox(
        root, textvariable=vibe_var,
        values=["pressure", "lift"], width=8
    ).grid(row=row, column=3, sticky="w", padx=10, pady=2)
    row += 1

    # Help
    help_text = (
        "Double‑click → tweak key, progression, toggle 16‑bar,\n"
        "then hit 'Generate MIDIs' for a 4×‑groove‑bass generator."
    )
    tk.Label(root, text=help_text, font=("TkDefaultFont", 8)).grid(
        row=row, column=0, columnspan=4, padx=10, pady=4)

    # Buttons
    def start_export():
        try:
            key       = key_var.get()
            mode      = mode_var.get()
            arp       = bool(arp_var.get())
            dur_beats = dur_beats_var.get()
            neural    = bool(neural_var.get())
            pyth      = bool(pythagorean_var.get())
            sixteen   = bool(sixteen_bar_var.get())
            swing_on  = bool(swing_quantize_enabled.get())
            swing_style = swing_style_var.get()
            vibe      = vibe_var.get()

            prog_text = prog_var.get().strip()
            prog =
